# Credentials
BOT_TOKEN=

# Discord app and access control
# Use comma-separated IDs for lists, for example: 111111111111111111,222222222222222222
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ADMIN_USER_IDS=
DISCORD_MODERATOR_ROLE_IDS=

# Provider API keys
# Providers without API keys are skipped. Configure order and models in config.yaml.
# AI_PROVIDER_OPENROUTER_API_KEY is also used by imageText when provider is openrouter.
AI_PROVIDER_OPENROUTER_API_KEY=
AI_PROVIDER_NVIDIA_API_KEY=
AI_PROVIDER_OPENAI_API_KEY=
AI_PROVIDER_GROQ_API_KEY=
AI_PROVIDER_TOGETHER_API_KEY=
AI_PROVIDER_DEEPINFRA_API_KEY=
AI_PROVIDER_FIREWORKS_API_KEY=

# Optional remote Qdrant credential
QDRANT_API_KEY=
